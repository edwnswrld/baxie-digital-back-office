# Copy to .env (gitignored) and fill in.

# Build-day ORGANIZATION key so agent usage draws from the $500 org credit pool
# (not a personal account). Verify the first call decrements org credits in the
# Anthropic Console.
ANTHROPIC_API_KEY=

# Optional: point the JobSource at Baxie staging Supabase (seeded, no client data).
# Leave blank to run on the public synthetic seed.
SUPABASE_URL=
SUPABASE_KEY=
